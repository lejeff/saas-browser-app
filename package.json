{
  "name": "saas-browser-platform",
  "private": true,
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "lint": "npm run lint -w app",
    "typecheck": "npm run typecheck -w app",
    "test": "npm run test -w app",
    "test:e2e": "npm run test:e2e -w app",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
