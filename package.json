{
  "name": "financial-planner",
  "private": true,
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "lint": "npm run lint -w app",
    "typecheck": "npm run typecheck -w app",
    "test": "npm run test -w app",
    "test:e2e": "npm run test:e2e -w app",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff -f",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:types": "supabase gen types typescript --local > app/src/types/supabase.ts"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "supabase": "2.95.1"
  }
}
