# -----------------------------------------------------------------------------
# Public environment (NEXT_PUBLIC_*) — baked into the client bundle at build.
# Safe to commit into Vercel's "Production" env. Never put secrets here.
# -----------------------------------------------------------------------------

# Canonical app URL. Local dev uses http://127.0.0.1:3000 by default.
# Production deploy lives at planner.boombaleia.com.
NEXT_PUBLIC_APP_URL=https://planner.boombaleia.com

# Supabase project (EU / Frankfurt).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# PostHog — EU cloud. Leave empty to disable analytics locally.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry DSN — EU region (https://xxx@oYYY.ingest.de.sentry.io/ZZZ).
# Public token by design (it can only write errors, not read). Leave empty to
# disable Sentry entirely — the SDK stays dormant when unset.
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Server-only environment — never sent to the browser.
# Set these in Vercel project settings (Production, Preview, Development).
# Production deploys fail to boot if any required variable is missing.
# -----------------------------------------------------------------------------

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx

RESEND_API_KEY=re_xxx

# SENTRY_AUTH_TOKEN is only needed in CI / on Vercel to upload source maps
# during `next build`. Scope when creating: project:releases + project:read.
SENTRY_AUTH_TOKEN=
